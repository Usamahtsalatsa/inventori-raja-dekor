{
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.9.0"
        }
    },
    "routes": [
        {
            "src": "/assets/(.*)",
            "dest": "/assets/$1"
        },
        {
            "src": "/bootstrap/(.*)",
            "dest": "/bootstrap/$1"
        },
        {
            "src": "/api/(.*)",
            "dest": "/api/$1"
        },
        {
            "src": "/(.*\\.php)",
            "dest": "/api/$1"
        },
        {
            "src": "/",
            "dest": "/api/login.php"
        },
        {
            "src": "/(.*)",
            "dest": "/api/$1"
        }
    ]
}
